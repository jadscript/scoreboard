# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────

# Runtime environment: development | production | test
NODE_ENV=development

# HTTP port the API will listen on
PORT=3000

# ──────────────────────────────────────────────
# CORS
# ──────────────────────────────────────────────

# Enable or disable CORS globally (true | false)
CORS_ENABLED=true

# Comma-separated list of allowed origins
# Example: http://localhost:5173,https://app.example.com
CORS_ORIGINS=http://localhost:5173

# ──────────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────────

# Full PostgreSQL connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://user:password@localhost:5432/scoreboard

# ──────────────────────────────────────────────
# Keycloak — backend uses dedicated client "api-cli" (see backend.mdc)
# ──────────────────────────────────────────────

# Base URL of the Keycloak server (no trailing slash)
KEYCLOAK_URL=http://localhost:8080

# Realm name (same as VITE_KEYCLOAK_REALM on the frontend)
KEYCLOAK_REALM=scoreboard

# API client ID: create confidential client "api-cli" in Keycloak Admin (not the SPA "web-cli")
KEYCLOAK_CLIENT_ID=api-cli

# Client secret: Keycloak Admin → Clients → api-cli → Credentials tab (keycloak-connect requires it)
KEYCLOAK_CLIENT_SECRET=replace-with-client-secret

# permissive | enforcing — permissive allows routes without @Resource until you adopt authorization
KEYCLOAK_POLICY_ENFORCEMENT=permissive

# online | offline — online validates with Keycloak; offline uses JWKS/cache
KEYCLOAK_TOKEN_VALIDATION=online
