# ──────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────

# Database superuser — used by both the app and Keycloak
POSTGRES_USER=scoreboard
POSTGRES_PASSWORD=change-me-strong-password
# Main application database
POSTGRES_DB=scoreboard

# ──────────────────────────────────────────────
# Keycloak
# ──────────────────────────────────────────────

# Bootstrap admin (only used on first run — rotate or disable afterwards)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-strong-password

# Public hostname where Keycloak is reachable (no scheme, no trailing slash)
# Example: auth.example.com
KC_HOSTNAME=auth.example.com
